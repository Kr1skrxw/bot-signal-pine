//@version=6
strategy("Bot Signal - EMA/RSI/Fractals", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════
tp1_pct            = input.float(1.0,  "TP1 (%)",           step=0.1,  group="Objectifs")
tp2_pct            = input.float(2.0,  "TP2 (%)",           step=0.1,  group="Objectifs")
sl_buffer          = input.float(0.1,  "SL Buffer (%)",     step=0.05, group="Stop Loss")
enable_break_even  = input.bool(true,  "Break even après TP1", group="Stop Loss")
webhook_freq       = input.string("once_per_bar_close", "Fréquence alerte",
                         options=["once_per_bar","once_per_bar_close","all"], group="Alertes")

// ═══════════════════════════════════════════════════════════════════════════════
// INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════
ema55  = ta.ema(close, 55)
ema233 = ta.ema(close, 233)
rsi13  = ta.rsi(close, 13)
sma8   = ta.sma(rsi13, 8)

// ═══════════════════════════════════════════════════════════════════════════════
// FRACTALS (Williams 5 bougies)
// ═══════════════════════════════════════════════════════════════════════════════
fractalHigh = high[2] > high[4] and high[2] > high[3] and high[2] > high[1] and high[2] > high[0]
fractalLow  = low[2]  < low[4]  and low[2]  < low[3]  and low[2]  < low[1]  and low[2]  < low[0]

var float lastFractalLow  = na
var float lastFractalHigh = na

if fractalLow
    lastFractalLow := low[2]
if fractalHigh
    lastFractalHigh := high[2]

// ═══════════════════════════════════════════════════════════════════════════════
// POSITION STATE
// ═══════════════════════════════════════════════════════════════════════════════
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
inTrade = inLong or inShort

newLongPosition  = strategy.position_size > 0 and strategy.position_size[1] <= 0
newShortPosition = strategy.position_size < 0 and strategy.position_size[1] >= 0
positionClosed   = strategy.position_size == 0 and strategy.position_size[1] != 0

entryPrice = strategy.position_avg_price

// ═══════════════════════════════════════════════════════════════════════════════
// TRAILING STOP + BREAK EVEN
// ═══════════════════════════════════════════════════════════════════════════════
var float trailSL_long   = na
var float trailSL_short  = na
var bool  tp1HitLong     = false
var bool  tp1HitShort    = false
var bool  breakEvenLong  = false
var bool  breakEvenShort = false

if newLongPosition
    trailSL_long   := not na(lastFractalLow) ? lastFractalLow * (1 - sl_buffer / 100) : close * 0.98
    tp1HitLong     := false
    breakEvenLong  := false

if newShortPosition
    trailSL_short  := not na(lastFractalHigh) ? lastFractalHigh * (1 + sl_buffer / 100) : close * 1.02
    tp1HitShort    := false
    breakEvenShort := false

// Détection TP1 atteint
if inLong and not tp1HitLong and high >= entryPrice * (1 + tp1_pct / 100)
    tp1HitLong := true

if inShort and not tp1HitShort and low <= entryPrice * (1 - tp1_pct / 100)
    tp1HitShort := true

// Break even auto après TP1 si le trailing n'a pas encore atteint l'entrée
if inLong and enable_break_even and tp1HitLong and not breakEvenLong and not na(trailSL_long) and trailSL_long < entryPrice
    trailSL_long  := entryPrice
    breakEvenLong := true

if inShort and enable_break_even and tp1HitShort and not breakEvenShort and not na(trailSL_short) and trailSL_short > entryPrice
    trailSL_short  := entryPrice
    breakEvenShort := true

// Mise à jour trailing fractal (ratchet)
if inLong and fractalLow
    newSL = low[2] * (1 - sl_buffer / 100)
    if na(trailSL_long) or newSL > trailSL_long
        trailSL_long := newSL

if inShort and fractalHigh
    newSL = high[2] * (1 + sl_buffer / 100)
    if na(trailSL_short) or newSL < trailSL_short
        trailSL_short := newSL

// Reset à la fermeture
if not inLong
    trailSL_long  := na
    tp1HitLong    := false
    breakEvenLong := false

if not inShort
    trailSL_short  := na
    tp1HitShort    := false
    breakEvenShort := false

trailUpdatedLong        = inLong  and not na(trailSL_long[1])  and trailSL_long  != trailSL_long[1]
trailUpdatedShort       = inShort and not na(trailSL_short[1]) and trailSL_short != trailSL_short[1]
breakEvenTriggeredLong  = inLong  and breakEvenLong  and trailSL_long  == entryPrice and trailSL_long[1]  < entryPrice
breakEvenTriggeredShort = inShort and breakEvenShort and trailSL_short == entryPrice and trailSL_short[1] > entryPrice

slTouchedLong  = inLong  and not na(trailSL_long)  and low  <= trailSL_long
slTouchedShort = inShort and not na(trailSL_short) and high >= trailSL_short

// ═══════════════════════════════════════════════════════════════════════════════
// CONDITIONS DE SIGNAL
// ═══════════════════════════════════════════════════════════════════════════════
bullTrend = ema55 > ema233
bearTrend = ema55 < ema233
rsiBull   = rsi13 > 50 and rsi13 > sma8
rsiBear   = rsi13 < 50 and rsi13 < sma8

longSignal  = bullTrend and rsiBull
shortSignal = bearTrend and rsiBear

longEntry  = longSignal  and not inTrade and not longSignal[1]
shortEntry = shortSignal and not inTrade and not shortSignal[1]

// ═══════════════════════════════════════════════════════════════════════════════
// TP LEVELS
// ═══════════════════════════════════════════════════════════════════════════════
longTP1  = close * (1 + tp1_pct / 100)
longTP2  = close * (1 + tp2_pct / 100)
shortTP1 = close * (1 - tp1_pct / 100)
shortTP2 = close * (1 - tp2_pct / 100)

entryLongSL  = not na(lastFractalLow)  ? lastFractalLow  * (1 - sl_buffer / 100) : close * 0.98
entryShortSL = not na(lastFractalHigh) ? lastFractalHigh * (1 + sl_buffer / 100) : close * 1.02

// ═══════════════════════════════════════════════════════════════════════════════
// STRATEGY ENTRIES
// ═══════════════════════════════════════════════════════════════════════════════
if longEntry
    strategy.entry("Long", strategy.long, comment="BUY")
    strategy.exit("TP1 Long",  "Long", qty_percent=33,  limit=longTP1,  stop=entryLongSL,  comment="TP1")
    strategy.exit("TP2 Long",  "Long", qty_percent=50,  limit=longTP2,  stop=entryLongSL,  comment="TP2")
    strategy.exit("TP3 Long",  "Long", qty_percent=100,                 stop=entryLongSL,  comment="TP Libre")

if shortEntry
    strategy.entry("Short", strategy.short, comment="SELL")
    strategy.exit("TP1 Short", "Short", qty_percent=33,  limit=shortTP1, stop=entryShortSL, comment="TP1")
    strategy.exit("TP2 Short", "Short", qty_percent=50,  limit=shortTP2, stop=entryShortSL, comment="TP2")
    strategy.exit("TP3 Short", "Short", qty_percent=100,                 stop=entryShortSL, comment="TP Libre")

// Fermeture manuelle sur trailing / break even
if slTouchedLong
    strategy.close("Long", comment=breakEvenLong ? "Break Even" : "Trailing SL")

if slTouchedShort
    strategy.close("Short", comment=breakEvenShort ? "Break Even" : "Trailing SL")

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTES WEBHOOK — alert() au lieu de alertcondition()
// alert() accepte les series string → pas de contrainte const string
// Créer UNE SEULE alerte TradingView sur l'indicateur avec
// condition "Any alert() call" → le message est généré dynamiquement
// ═══════════════════════════════════════════════════════════════════════════════

f_r(val) =>
    str.tostring(math.round(val, 6))

if longEntry
    msg = '{"action":"buy","symbol":"' + syminfo.ticker + '","price":' + f_r(close) + ',"sl":' + f_r(entryLongSL) + ',"tp1":' + f_r(longTP1) + ',"tp2":' + f_r(longTP2) + ',"tf":"' + timeframe.period + '"}'
    alert(msg, alert.freq_once_per_bar_close)

if shortEntry
    msg = '{"action":"sell","symbol":"' + syminfo.ticker + '","price":' + f_r(close) + ',"sl":' + f_r(entryShortSL) + ',"tp1":' + f_r(shortTP1) + ',"tp2":' + f_r(shortTP2) + ',"tf":"' + timeframe.period + '"}'
    alert(msg, alert.freq_once_per_bar_close)

if breakEvenTriggeredLong
    msg = '{"action":"update_sl","mode":"break_even","side":"long","symbol":"' + syminfo.ticker + '","new_sl":' + f_r(entryPrice) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if breakEvenTriggeredShort
    msg = '{"action":"update_sl","mode":"break_even","side":"short","symbol":"' + syminfo.ticker + '","new_sl":' + f_r(entryPrice) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if trailUpdatedLong and not breakEvenTriggeredLong
    msg = '{"action":"update_sl","side":"long","symbol":"' + syminfo.ticker + '","new_sl":' + f_r(trailSL_long) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if trailUpdatedShort and not breakEvenTriggeredShort
    msg = '{"action":"update_sl","side":"short","symbol":"' + syminfo.ticker + '","new_sl":' + f_r(trailSL_short) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if slTouchedLong
    reason = breakEvenLong ? 'break_even' : 'trailing_sl'
    msg = '{"action":"close","side":"long","reason":"' + reason + '","symbol":"' + syminfo.ticker + '","sl_level":' + f_r(trailSL_long) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

if slTouchedShort
    reason = breakEvenShort ? 'break_even' : 'trailing_sl'
    msg = '{"action":"close","side":"short","reason":"' + reason + '","symbol":"' + syminfo.ticker + '","sl_level":' + f_r(trailSL_short) + ',"price":' + f_r(close) + '}'
    alert(msg, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════════════════
// DISPLAY
// ═══════════════════════════════════════════════════════════════════════════════
plot(ema55,  "EMA 55",  color=color.new(color.blue,   0), linewidth=2)
plot(ema233, "EMA 233", color=color.new(color.orange, 0), linewidth=2)

hline(50, "Mid", color=color.gray, linestyle=hline.style_dashed)
plot(rsi13, "RSI 13",      color=color.new(color.purple, 0), display=display.pane)
plot(sma8,  "SMA 8 (RSI)", color=color.new(color.red,    0), display=display.pane)

plotshape(fractalHigh, "Fractal Haut", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.tiny, offset=-2)
plotshape(fractalLow,  "Fractal Bas",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.tiny, offset=-2)

plotshape(longEntry,  "Signal ACHAT", shape.labelup,   location.belowbar, color.new(color.green, 0), text="BUY",  textcolor=color.white, size=size.small)
plotshape(shortEntry, "Signal VENTE", shape.labeldown, location.abovebar, color.new(color.red,   0), text="SELL", textcolor=color.white, size=size.small)

plot(inLong  and not na(trailSL_long)  ? trailSL_long  : na, "Trailing SL Long",  color=color.new(color.red, 20), linewidth=2, style=plot.style_linebr)
plot(inShort and not na(trailSL_short) ? trailSL_short : na, "Trailing SL Short", color=color.new(color.red, 20), linewidth=2, style=plot.style_linebr)

plotshape(trailUpdatedLong  and not breakEvenTriggeredLong,  title="Trail update long",  style=shape.circle,  location=location.absolute, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(trailUpdatedShort and not breakEvenTriggeredShort, title="Trail update short", style=shape.circle,  location=location.absolute, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(breakEvenTriggeredLong,  title="Break even long",  style=shape.diamond, location=location.absolute, color=color.new(color.aqua, 0), size=size.small)
plotshape(breakEvenTriggeredShort, title="Break even short", style=shape.diamond, location=location.absolute, color=color.new(color.aqua, 0), size=size.small)
